script:
  job_name: ood_wheel
  queue_name: <%= queue %>
  <%- if email.present? -%>
  email: <%= email %>
  email_on_started: true
  <%- end -%>
  native:
    <%- if queue == "ondemand-reserved" -%>
      - "-t"
      - "<%= prepost_reserved_hours %>:00:00"
      - "-n"
      - <%= cores.to_i %>
      - "--mem"
      - "<%= memory %>G"
    <%- elsif queue == "gpu1" -%>
      - "-t"
      - "<%= prepost1_hours %>:00:00"
      - "-n"
      - <%= cores.to_i %>
      - "--mem"
      - "<%= memory %>G"
    <%- elsif queue == "gpu2" then -%>
      - "-t"
      - "<%= prepost2_hours %>:00:00"
      - "-n"
      - <%= cores.to_i %>
      - "--mem"
      - "<%= memory %>G"
    <%- elsif queue == "mem1" then -%>
      - "-t"
      - "<%= prepost1_hours %>:00:00"
      - "-n"
      - <%= cores.to_i %>
      - "--mem"
      - "<%= mem1_memory %>G"
    <%- elsif queue == "mem2" then -%>
      - "-t"
      - "<%= prepost2_hours %>:00:00"
      - "-n"
      - <%= cores.to_i %>
      - "--mem"
      - "<%= memory %>G"
    <%- end -%>
batch_connect:
  template: "basic"
