script:
  job_name: ood_wheel
  queue_name: <%= queue %>
  <%- if email.present? -%>
  email: <%= email %>
  email_on_started: true
  <%- end -%>
  native:
    <%- if queue == "small-dormant-lingering-jobs-only" -%>
      - "-t"
      - "<%= prepost_wheel_hours %>:00:00"
      - "-n"
      - <%= gpu1_cores.to_i %>
      - "--mem"
      - "<%= gpu1_memory %>G"
    <%- elsif queue == "gpu1" -%>
      - "-t"
      - "<%= prepost1_hours %>:00:00"
      - "-n"
      - <%= gpu1_cores.to_i %>
      - "--mem"
      - "<%= gpu1_memory %>G"
    <%- elsif queue == "gpu2" then -%>
      - "-t"
      - "<%= prepost2_hours %>:00:00"
      - "-n"
      - <%= gpu2_cores.to_i %>
      - "--mem"
      - "<%= gpu2_memory %>G"
    <%- elsif queue == "mem1" then -%>
      - "-t"
      - "<%= prepost1_hours %>:00:00"
      - "-n"
      - <%= mem1_cores.to_i %>
      - "--mem"
      - "<%= mem1_memory %>G"
    <%- elsif queue == "mem2" then -%>
      - "-t"
      - "<%= prepost2_hours %>:00:00"
      - "-n"
      - <%= mem2_cores.to_i %>
      - "--mem"
      - "<%= mem2_memory %>G"
    <%- end -%>
batch_connect:
  template: "basic"

