<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
-%>
---
title: WHEEL
form:
  <%= form_cluster("prepost") %>
  <%= form_queue("workflow") %>
  <%= form_reserved_hours() %>
  <%= form_prepost1_hours() %>
  <%= form_prepost2_hours() %>
  <%= form_reserved_cores(2, 8) %>
  <%= form_gpu1_cores(2, 8) %>
  <%= form_gpu2_cores(2, 8) %>
  <%= form_mem1_cores(2, 8) %>
  <%= form_mem2_cores(2, 8) %>
  <%= form_reserved_memory(8, 32) %>
  <%= form_gpu1_memory(8, 32) %>
  <%= form_gpu2_memory(8, 32) %>
  <%= form_mem1_memory(8, 32) %>
  <%= form_mem2_memory(8, 32) %>
  <%= form_email(false) %>
  - key_mode
attributes:
<%= form_attr() %>
  key_mode:
    kabel: Key Mode
    widget: select
    help: |
      Select how to use the SSH key pair for connection to Fugaku.
      "Single-use key pair" is selected, the key pair are automatically generated by the WHEEL instance and update your $HOME/.ssh/authorized_keys and $HOME/.ssh/config.
      The key pair will be deleted when the WHEEL insntance is finished.
    options:
      - Your own key pair
      - Single-use key pair
