<%-
  require '/var/www/ood/apps/sys/ondemand_apps/misc/cache.rb'
  groups = get_groups()
-%>
---
title: WHEEL
form:
  - cluster
  - queue
  - group
  - prepost_reserved_hours
  - prepost1_hours
  - prepost2_hours
  - cores
  - memory
  - email
attributes:
  cluster:
    widget: hidden_field
    value: prepost
  queue:
    label: Queue
    widget: select
    options:
      - [ "prepost-ondemand-reserved", "ondemand-reserved",
          data-hide-group: true,
          data-hide-prepost1-hours: true,
          data-hide-prepost2-hours: true ]
      - [ "prepost-gpu1", "gpu1",
          data-hide-group: true,
          data-hide-prepost-reserved-hours: true,
          data-hide-prepost2-hours: true ]
      - [ "prepost-gpu2", "gpu2",
          data-hide-group: true,
          data-hide-prepost-reserved-hours: true,
          data-hide-prepost1-hours: true ]
      - [ "prepost-mem1", "mem1",
          data-hide-group: true,
          data-hide-prepost-reserved-hours: true,
          data-hide-prepost2-hours: true ]
      - [ "prepost-mem2", "mem2",
          data-hide-group: true,
          data-hide-prepost-reserved-hours: true,
          data-hide-prepost1-hours: true ]
  group:
    label: Group
    widget: select
    options:
    <%- groups.each do |group| -%>
      - <%= group %>
    <%- end -%>
  prepost_reserved_hours:
    widget: number_field
    label: Elapsed time (1 - 720 hours)
    value: 1
    min: 1
    max: 720
    step: 1
    required: true
  prepost1_hours:
    widget: number_field
    label: Elapsed time (1 - 3 hours)
    value: 1
    min: 1
    max: 3
    step: 1
    required: true
  prepost2_hours:
    widget: number_field
    label: Elapsed time (1 - 24 hours)
    value: 1
    min: 1
    max: 24
    step: 1
    required: true
  cores:
    widget: number_field
    label: Number of CPU cores (2 - 8)
    value: 2
    min: 2
    max: 8
    step: 1
    required: true
  memory:
    widget: number_field
    label: Required memory (8 - 32 GB)
    value: 8
    min: 8
    max: 32
    step: 1
    required: true
  email:
    widget: email_field
    label: Email (You will receive an email when it starts)
