<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
-%>
---
title: WHEEL
form:
  <%= form_cluster("prepost") %>
  <%= form_queue("workflow") %>
  <%= form_hours("reserved") %>
  <%= form_hours("prepost1") %>
  <%= form_hours("prepost2") %>
  <%= form_cores("reserved", 2, 8) %>
  <%= form_cores("gpu1", 2, 8) %>
  <%= form_cores("gpu2", 2, 8) %>
  <%= form_cores("mem1", 2, 8) %>
  <%= form_cores("mem2", 2, 8) %>
  <%= form_memory("reserved", 8, 32) %>
  <%= form_memory("gpu1", 8, 32) %>
  <%= form_memory("gpu2", 8, 32) %>
  <%= form_memory("mem1", 8, 32) %>
  <%= form_memory("mem2", 8, 32) %>
  <%= form_email(false) %>
  - key_mode
attributes:
<%= form_attr() %>
  key_mode:
    kabel: Key Mode
    widget: select
    help: |
      Select how to use the SSH key pair for connection to Fugaku.
      "Single-use key pair" is selected, the key pair are automatically generated by the WHEEL instance and update your $HOME/.ssh/authorized_keys and $HOME/.ssh/config.
      The key pair will be deleted when the WHEEL insntance is finished.
    options:
      - Your own key pair
      - Single-use key pair
