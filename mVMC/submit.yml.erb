<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
-%>
---
script:
  job_name: ood_mvmc
  queue_name: <%= queue %>
  <%= submit_email(email, false) %>
  <% if exec_file == "vmc.out" then %>
  <%= submit_native_fugaku(queue, fugaku_small_hours, fugaku_small_free_hours, fugaku_small_nodes, fugaku_small_procs, fugaku_large_hours, fugaku_large_free_hours, fugaku_large_nodes, fugaku_large_procs, fugaku_group, fugaku_mode) %>
  <% else %>
  <%= submit_native_fugaku(queue, fugaku_small_hours, fugaku_small_free_hours, 1, 1, fugaku_large_hours, fugaku_large_free_hours, 1, 1, fugaku_group, fugaku_mode) %>
  <% end %>
batch_connect:
  template: "basic"
  script_wrapper: |
    <%= submit_env(fugaku_threads, "mvmc", version) %>
    <%= submit_fugaku_llio_exec_file(queue, fugaku_large_nodes, fugaku_large_procs, exec_file) %>
    <%= submit_fugaku_llio(queue, fugaku_llio, input_file) %>
    <%= submit_working_dir(working_dir) %>
    
    if [ "<%= exec_file %>" = "vmc.out" ]; then
      mpiexec vmc.out <%= se_mode %> "<%= input_file %>"
    else
      OUTPUT_FILE="<%= output_file %>"
      [ "<%= output_file %>" = "" ] && OUTPUT_FILE=output.${PJM_JOBID}
      UHF "<%= input_file %>" &> "${OUTPUT_FILE}"
    fi
