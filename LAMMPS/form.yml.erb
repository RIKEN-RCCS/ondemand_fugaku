<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/form.rb'
  # spack versions lammps -s
  versions = ["20220623.2"]
-%>
---
form:
  <%= form_cluster("fugaku") %>
  <%= form_queue("fugaku_small_and_large") %>
  <%= form_volume() %>
  <%= form_group() %>
  <%= form_fugaku_small_hours() %>
  <%= form_fugaku_small_free_hours() %>
  <%= form_fugaku_small_nodes() %>
  <%= form_fugaku_small_procs() %>
  <%= form_fugaku_large_hours() %>
  <%= form_fugaku_large_free_hours() %>
  <%= form_fugaku_large_nodes() %>
  <%= form_fugaku_large_procs() %>
  <%= form_fugaku_threads() %>
  <%= form_mode() %>
  <%= form_version(versions) %>
  <%= form_filename("mpiexec lmp -in <input file>") %>
  <%= form_options("e.g. -pk omp 2") %>
  <%= form_email(false) %>
attributes:
<%= form_attr() %>
