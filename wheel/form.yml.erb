<%-
  require '/var/www/ood/apps/sys/ondemand_apps/misc/cache.rb'
  groups = get_groups()
-%>
---
title: WHEEL Workflow Management Tool
form:
  - cluster
  - queue
  - group
  - prepost_wheel_hours
  - prepost1_hours
  - prepost2_hours
  - gpu1_cores
  - gpu2_cores
  - mem1_cores
  - mem2_cores
  - gpu1_memory
  - gpu2_memory
  - mem1_memory
  - mem2_memory
  - email
attributes:
  queue:
    label: Queue
    widget: select
    options:
      - [ "prepost-wheel", "small-dormant-lingering-jobs-only",
          data-set-cluster: "prepost",
          data-hide-cluster: true,
          data-hide-group: true,
          data-hide-prepost1-hours: true,
          data-hide-prepost2-hours: true,
          data-hide-gpu2-cores: true,
          data-hide-mem1-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true ]
      - [ "prepost-gpu1", "gpu1", data-set-cluster: "prepost",
          data-hide-cluster: true,
          data-hide-group: true,
          data-hide-prepost-wheel-hours: true,
          data-hide-prepost2-hours: true,
          data-hide-gpu2-cores: true,
          data-hide-mem1-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true ]
      - [ "prepost-gpu2", "gpu2", data-set-cluster: "prepost",
          data-hide-cluster: true,
          data-hide-group: true,
          data-hide-prepost-wheel-hours: true,
          data-hide-prepost1-hours: true,
          data-hide-gpu1-cores: true,
          data-hide-mem1-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu1-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true ]
      - [ "prepost-mem1", "mem1", data-set-cluster: "prepost",
          data-hide-cluster: true,
          data-hide-group: true,
          data-hide-prepost-wheel-hours: true,
          data-hide-prepost2-hours: true,
          data-hide-gpu1-cores: true,
          data-hide-gpu2-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu1-memory: true,
          data-hide-gpu2-memory: true,
          data-hide-mem2-memory: true ]
      - [ "prepost-mem2", "mem2", data-set-cluster: "prepost",
          data-hide-cluster: true,
          data-hide-group: true,
          data-hide-prepost-wheel-hours: true,
          data-hide-prepost1-hours: true,
          data-hide-gpu1-cores: true,
          data-hide-gpu2-cores: true,
          data-hide-mem1-cores: true,
          data-hide-gpu1-memory: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true ]
  group:
    label: Group
    widget: select
    options:
    <%- groups.each do |group| -%>
      - <%= group %>
    <%- end -%>
  prepost_wheel_hours:
    widget: number_field
    label: Elapsed Time (6 - 168 hours)
    value: 6
    min: 6
    max: 168
    step: 6
  prepost1_hours:
    widget: number_field
    label: Elapsed Time (1 - 3 hours)
    value: 1
    min: 1
    max: 3
    step: 1
  prepost2_hours:
    widget: number_field
    label: Elapsed Time (1 - 24 hours)
    value: 1
    min: 1
    max: 24
    step: 1
  gpu1_cores:
    widget: number_field
    label: Number of CPU cores (1 - 72)
    value: 1
    min: 1
    max: 72
    step: 1
  gpu2_cores:
    widget: number_field
    label: Number of CPU cores (1 - 36)
    value: 1
    min: 1
    max: 36
    step: 1
  mem1_cores:
    widget: number_field
    label: Number of CPU cores (1 - 224)
    value: 1
    min: 1
    max: 224
    step: 1
  mem2_cores:
    widget: number_field
    label: Number of CPU cores (1 - 56)
    value: 1
    min: 1
    max: 56
    step: 1
  gpu1_memory:
    widget: number_field
    label: Required memory (5 - 186 GB)
    value: 5
    min: 5
    max: 186
    step: 1
  gpu2_memory:
    widget: number_field
    label: Required memory (5 - 93 GB)
    value: 5
    min: 5
    max: 93
    step: 1
  mem1_memory:
    widget: number_field
    label: Required memory (5 - 5020 GB)
    value: 5
    min: 5
    max: 5020
    step: 1
  mem2_memory:
    widget: number_field
    label: Required memory (5 - 1500 GB)
    value: 5
    min: 5
    max: 1500
    step: 1
  email:
    widget: email_field
    label: Email (You will receive an email when it starts)
