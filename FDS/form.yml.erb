<%-
  require '/var/www/ood/apps/sys/ondemand_apps/misc/form.rb'
  # spack versions quantum-espresso -s
  versions = ["6.7.9"]
-%>
---
form:
  - cluster
  - queue
  - volume
  - group
  - fugaku_hours
  - fugaku_nodes
  - fugaku_procs
  - fugaku_threads
  - mode
  - version
  - filename
  - email
attributes:
  <%= get_cluster("fugaku") %>
  <%= get_queue("fugaku_small") %>
  <%= get_volume() %>
  <%= get_group() %>
  <%= get_fugaku_hours() %>
  <%= get_fugaku_nodes() %>
  <%= get_fugaku_procs() %>
  <%= get_fugaku_threads() %>
  <%= get_mode() %>
  <%= get_version(versions) %>
  <%= get_filename() %>
  <%= get_email(1) %>
