script:
  job_name: ood_fds_smv
  queue_name: <%= queue %>
  <%- if email.present? -%>
  email: <%= email %>
  email_on_started: true
  email_on_terminated: true
  <%- end -%>
  native:
    - "--no-check-directory -g <%= group %>"
    <%- if volume == "/vol0004" -%>
    - "-x PJM_LLIO_GFSCACHE=/vol0004"
    <%- else -%>
    - "-x PJM_LLIO_GFSCACHE=/vol0004:<%= volume %>"
    <%- end -%>
    <%- if mode == "Boost" -%>
    - "-L freq=2200"
    <%- elsif mode == "Eco" -%>
    - "-L eco_state=2"
    <%- elsif mode == "Boost + Eco" -%>
    - "-L freq=2200,eco_state=2"
    <%- end -%>
    <%- if queue == "small" -%>
    - "-L elapse=<%= hours_in_three_days %>:00:00 -L node=<%= small_nodes %> --mpi proc=<%= small_procs %>"
    <%- elsif queue == "large" -%>
    - "-L elapse=<%= hours_in_one_day %>:00:00 -L node=<%= large_nodes %> --mpi proc=<%= large_procs %>"
    <%- else -%>
    - "-L elapse=<%= hours_in_one_day %>:00:00 -L node=<%= middle_nodes %> --mpi proc=<%= middle_procs %>"
    <%- end -%>
batch_connect:
  template: "basic"
  script_wrapper: |
    #!/bin/bash
    set -x

    export OMP_NUM_THREADS=<%= threads %>
    . /vol0004/apps/oss/spack/share/spack/setup-env.sh
    spack load fds@<%= version %>
    cd <%= working_dir %>
    time mpiexec <%= binary679 %> 
