<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
  # spack versions fugaku-frontistr -s  
  versions=["master"]
  # spack find --paths fugaku-frontistr@master
  ff_master = form_load_cache("fugaku-frontistr_master")
-%>
---
title: FrontISTR
form:
  <%= form_cluster("fugaku") %>
  <%= form_queue("fugaku_small") %>
  <%= form_fugaku_group() %>
  <%= form_hours("fugaku_small") %>
  <%= form_hours("fugaku_small_free") %>
  <%= form_nodes("fugaku_small") %>
  <%= form_procs("fugaku_small") %>
  <%= form_fugaku_threads() %>
  <%= form_fugaku_mode() %>
  <%= form_working_dir() %>
  <%= form_version(versions) %>
  <%= form_select("pre_execute", "Execute hecmw_part1 in advance ?", [[ "mpiexec -n 1 hecmw_part1", "mpiexec -n 1 hecmw_part1" ], [ "No", "" ]]) %>
  <%= form_exec(versions[0], ff_master, "fistr1") %>
  <%= form_email(false) %>
attributes:
<%= form_attr() %>
