<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
-%>
---
script:
  job_name: ood_genesis
  queue_name: <%= queue %>
  <%= submit_email(email, false) %>
  <%= submit_native_fugaku(queue, fugaku_small_hours, fugaku_small_free_hours, fugaku_small_nodes, fugaku_small_procs, fugaku_large_hours, fugaku_large_free_hours, fugaku_large_nodes, fugaku_large_procs, fugaku_group, fugaku_mode) %>
batch_connect:
  template: "basic"
  script_wrapper: |
    <%= submit_env(fugaku_threads, version) %>
    <%= submit_fugaku_llio_exec_file(queue, fugaku_large_nodes, fugaku_large_procs, executable) %>
    <%= submit_fugaku_llio(queue, fugaku_llio, input_file) %>
    cd `dirname "<%= input_file %>"`
    mpiexec <%= executable %> "<%= input_file %>"
