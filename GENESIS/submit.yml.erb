<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'

  added_fugaku_queues = submit_added_fugaku_queues()
  hours = submit_hours(queue, fugaku_small_hours, fugaku_small_free_hours, fugaku_large_hours, fugaku_large_free_hours, fugaku_cd_portal_hours, fugaku_pt_aug_hours, fugaku_pt_feb_hours, NOT_USED, NOT_USED, NOT_USED)
  nodes = submit_nodes(queue, fugaku_small_nodes, fugaku_large_nodes, fugaku_cd_portal_nodes, fugaku_pt_aug_nodes, fugaku_pt_feb_nodes)
  procs = submit_procs(queue, fugaku_small_procs, fugaku_large_procs, fugaku_cd_portal_procs, fugaku_pt_aug_procs, fugaku_pt_feb_procs)
-%>
---
script:
<%= submit_job_name("ood_genesis") %>
<%= submit_queue_name(queue) %>
<%= submit_email(email, false) %>
<%= submit_native(queue, hours, nodes, procs, NOT_USED, NOT_USED, fugaku_group, fugaku_mode, fugaku_statistical_info, input_file, NOT_USED, added_fugaku_queues, NOT_USED) %>
batch_connect:
  template: "basic"
  script_wrapper: |
    <%= submit_env(fugaku_threads, version) %>
    <%= submit_fugaku_llio_exec_file(queue, fugaku_large_nodes, fugaku_large_procs, executable) %>
    <%= submit_fugaku_llio(queue, fugaku_llio, input_file) %>
    cd `dirname "<%= input_file %>"`
    mpiexec <%= executable %> "<%= input_file %>"
