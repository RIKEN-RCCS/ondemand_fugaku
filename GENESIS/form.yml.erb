<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/form.rb'
  
  versions = [ ["2.0.3", "ff4qwif"], ["1.6.0", "m7jm7cb"] ]
  # spack find --paths 
  execs = ["atdyn", "spdyn"]
-%>
---
title: GENESIS
form:
  <%= form_cluster("fugaku") %>
  <%= form_queue("fugaku_small_and_large") %>
