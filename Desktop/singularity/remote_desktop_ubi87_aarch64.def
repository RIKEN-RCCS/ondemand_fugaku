Bootstrap: docker
From: redhat/ubi8:8.6-943

%files
  /etc/pki/entitlement /etc/pki/
  /etc/yum.repos.d/redhat.repo

%post
  rm -f /etc/yum.repos.d/ubi.repo
  dnf --releasever=8.7 -y upgrade
  dnf --releasever=8.7 -y install gcc gcc-gfortran gcc-c++ perl java vim emacs zsh ksh tcsh git cmake numactl boost boost-devel dnf-plugins-core wget hostname
  dnf -y install https://dl.fedoraproject.org/pub/epel/epel-release-latest-8.noarch.rpm
  dnf --releasever=8.7 -y install xorg-x11-apps evince glx-utils systemd-libs sssd python2-pip Lmod glibc-langpack-en xdg-user-dirs
  dnf --releasever=8.7 -y install mesa-libGLU hwloc-libs lm_sensors-libs libXp ghostscript gedit gedit-plugins pcre2-utf16 ncurses-compat-libs
  dnf --releasever=8.7 -y install gnuplot ImageMagick ncview freeglut freeglut-devel
  dnf --releasever=8.7 -y install vlgothic-fonts vlgothic-p-fonts google-noto-sans-cjk-jp-fonts adobe-source-han-sans-jp-fonts
  dnf --releasever=8.7 -y --skip-broken groupinstall 'Development Tools' 'Infiniband Support' 'base-x' 'Internet Browser' 'Base' 'Xfce'
  pip2 install ts
  dnf --releasever=8.7 -y install https://yum.osc.edu/ondemand/latest/compute/el8Server/x86_64/python3-websockify-0.10.0-1.el8.noarch.rpm
  dnf --releasever=8.7 -y install libX11-devel libXi-devel libXt-devel pam-devel java-1.8.0-openjdk-devel
  wget https://turbovnc.org/pmwiki/uploads/Downloads/TurboVNC.repo
  mv TurboVNC.repo /etc/yum.repos.d
  dnf --releasever=8.7 -y install turbovnc-3.0.3-20230227
  dnf remove -y python2-pip xfce4-screensaver
  update-alternatives --set python /usr/bin/python3
  dnf --releasever=8.7 -y --skip-broken install paraview paraview-devel paraview-mpich-devel paraview-openmpi-devel paraview-doc qt5-devel protobuf-devel
  #
  # For Fujitsu TCS
  cat <<EOF > /etc/yum.repos.d/Fugaku.repo
[FUGAKU-AppStream]
name=FUGAKU-AppStream
baseurl=http://10.4.38.1/pxinst/repos/FUGAKU/AppStream
enabled=1
gpgcheck=0

[FUGAKU-BaseOS]
name=FUGAKU-BaseOS
baseurl=http://10.4.38.1/pxinst/repos/FUGAKU/BaseOS
enabled=1
gpgcheck=0
EOF
  rpm -e --nodeps pmix
  dnf --releasever=8.7 -y install xpmem libevent tcl less hwloc openssh-clients gcc-c++ elfutils-libelf-devel FJSVpxtof FJSVpxple FJSVpxpsm FJSVpxkrm FJSVxoslibmpg
  #
  dnf -y --releasever=8.7 install rclone rclone-browser
  #
  dnf -y --releasever=8.7 install wayland-devel libxkbcommon-devel wayland-protocols-devel extra-cmake-modules
  #
  # GLFW
  dnf -y install libXrandr-devel libXinerama-devel libXcursor-devel
  wget https://github.com/glfw/glfw/releases/download/3.3.2/glfw-3.3.2.zip
  unzip glfw-3.3.2.zip; cd glfw-3.3.2; cmake -DBUILD_SHARED_LIBS=ON -S . -B build; cd build; make install
  cd ../../
  rm -rf glfw-3.3.2 glfw-3.3.2.zip
  #
  dnf clean all
  rm -f /etc/pki/entitlement/*
  rm -f /etc/yum.repos.d/redhat.repo /etc/yum.repos.d/Fugaku.repo
  
