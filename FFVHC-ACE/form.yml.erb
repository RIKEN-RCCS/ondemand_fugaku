<%
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
  # spack versions ffvhc-ace -s
  versions = ["0.1"]
%>
---
title: FFVHC-ACE
form:
<%= form_queue("fugaku_small_and_large") %>
<%= form_version(versions) %>
<%= form_input_file() %>
<%= form_select("omp_stacksize", "export OMP_STACKSIZE", ["(none)", "1g"]) %>
<%= form_select("tofu_eager_limit", "export OMPI_MCA_btl_tofu_eager_limit", ["(none)", "128000"]) %>
<%= form_email(false) %>
attributes:
<%= form_attr() %>
