<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
-%>
---
script:
  job_name: ood_alamode
  queue_name: <%= queue %>
  <%= submit_email(email, false) %>
  <%= submit_native_fugaku_small(queue, fugaku_small_hours, fugaku_small_free_hours, fugaku_small_nodes, fugaku_small_procs,
  fugaku_group, fugaku_mode, fugaku_statistical_info, input_file) %>
batch_connect:
  template: "basic"
  script_wrapper: |
    <%= submit_env(fugaku_threads, "alamode", version) %>
    <%= submit_working_dir(working_dir) %>
    mpiexec anphon "<%= input_file %>"
