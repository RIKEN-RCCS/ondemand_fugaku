<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/submit.rb'
-%>
---
script:
  job_name: ood_scale
  queue_name: <%= queue %>
  <%= submit_email(email, false) %>
  <%= submit_native_fugaku(queue, fugaku_small_hours, fugaku_small_free_hours, fugaku_small_nodes, fugaku_small_procs, fugaku_large_hours, fugaku_large_free_hours, fugaku_large_nodes, fugaku_large_procs, group, volume, mode) %>
batch_connect:
  template: "basic"
  script_wrapper: |
    <%= submit_env(fugaku_threads, "scale", version) %>
    export FORT90L=-Wl,-T
    export PLE_MPI_STD_EMPTYFILE=off
    export OMP_WAIT_POLICY=active
    export FLIB_BARRIER=HARD
    
    <%= submit_llio_dir(fugaku_llio, queue, working_dir) %>
    cd <%= working_dir %>

    ## scale-rm_pp
    if [ "<%= input_file_scale_rm_pp %>" != "" ]; then
      <%= submit_llio_exec_file(fugaku_llio, queue, "scale-rm_pp") %>
      mpiexec scale-rm_pp <%= input_file_scale_rm_pp %>
    fi

    ## scale-rm_init
    if [ "<%= input_file_scale_rm_init %>" != "" ]; then
      <%= submit_llio_exec_file(fugaku_llio, queue, "scale-rm_init") %>
      mpiexec scale-rm_init <%= input_file_scale_rm_init %>
    fi

    ## scale-rm
    if [ "<%= input_file_scale_rm %>" != "" ]; then
      <%= submit_llio_exec_file(fugaku_llio, queue, "scale-rm") %>
      mpiexec scale-rm <%= input_file_scale_rm %>
    fi

    ## sno
    if [ "<%= input_file_sno %>" != "" ]; then
      <%= submit_llio_exec_file(fugaku_llio, queue, "sno") %>
      mpiexec sno <%= input_file_sno %>
    fi

    ## net2g
    if [ "<%= input_file_net2g %>" != "" ]; then
      <%= submit_llio_exec_file(fugaku_llio, queue, "net2g") %>
      mpiexec net2g <%= input_file_net2g %>
    fi
    