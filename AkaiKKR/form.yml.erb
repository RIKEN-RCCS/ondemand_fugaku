<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
  
  # spack versions akaikkr -s
  versions = ["2021v001", "2002v010"]
-%>
---
title: AkaiKKR
form:
  <%= form_cluster("fugaku") %>
  <%= form_queue("fugaku_small") %>
  <%= form_volume() %>
  <%= form_group() %>
  <%= form_fugaku_small_hours() %>
  <%= form_fugaku_small_free_hours() %>
  <%= form_fugaku_threads("") %>
  <%= form_mode() %>
  <%= form_version(versions) %>
  <%= form_working_dir(false) %>
  <%= form_input_file(true, "specx < [input] > [output]") %>
  <%= form_output_file(true, "specx < [input] > [output]") %>
  <%= form_email(false) %>
attributes:
<%= form_attr() %>
