<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
-%>

<%= output_xfce(context.opengl_with_nvidia, context.gpus_per_node, context.queue) %>
FTYPE=""
if [ "<%= context.ftype %>" = "psf" ]; then
  FTYPE="-psf"
elif [ "<%= context.ftype %>" = "pdb" ]; then
  FTYPE="-pdb"
elif [ "<%= context.ftype %>" = "dcd" ]; then
  FTYPE="-dcd"
fi

if [ "${_OPENGL_WITH_NVIDIA_OPTION}" = "" ]; then
  xfce4-terminal -e 'bash -c "/vol0004/apps/oss/vmd/bin/vmd ${FTYPE} <%= context.input_file %>; exec bash"' -T "VMD Terminal" --disable-server &
else
  xfce4-terminal -e 'bash -c "__NV_PRIME_RENDER_OFFLOAD=1 __GLX_VENDOR_LIBRARY_NAME=nvidia /vol0004/apps/oss/vmd/bin/vmd ${FTYPE} <%= context.input_file %>; exec bash"' -T "VMD Terminal" --disable-server &
fi

xfce4-session
