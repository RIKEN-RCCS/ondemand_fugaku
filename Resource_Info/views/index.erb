<style type="text/css">
table tr:nth-child(even) td {
  background: #FFDBC9;
  border: solid 2px #888888;
  vertical-align: middle;
  font-size: 16px;
}
table tr:nth-child(odd) td {
  border: solid 2px #888888;
  vertical-align: middle;
  font-size: 16px;
}
th {
  background-color: #880000;
  color: white;
  text-align: center;
  font-weight: bold;
  vertical-align: middle;
  font-size: 16px;
}
td {
  text-align: right;
}
</style>
<h1><%= title %> <font size="3">(Updated at <%= get_update_time() %>)</font></h1>
<p>
<font size="5">Resource usage for each user by group.</font>
</p>
<% @groups.each_with_index do |g, i| %>
  <h2><%= g %></h2>
  <table class="table table-bordered" style="border: solid 2px #888888;">
    <tr>
      <th style="vertical-align: middle;" rowspan="2">User</th>
      <th colspan="4">Resource (NH)</th>
    </tr>
    <tr>
      <th>Limit</th>
      <th>Usage</th>
      <th>Available</th>
      <th>Ratio</th>
    </tr>
    <% @resource_info[i].each do |d| %>
    <tr>
      <% user  = d[0] %>
      <% limit = d[1] %>
      <% usage = d[2] %>
      <% avail = d[3] %>
      <% if user == ENV['USER'] %>
      <td style="color: red; font-weight: bold"><%= user %></td>
      <% else %>
      <td><%= user %></td>
      <% end %>
      <% if limit != -1 %>
      <td><%= num_with_commas(limit) %></td>
      <td><%= num_with_commas(usage) %></td>
      <td><%= num_with_commas(avail) %></td>
      <td>
        <div class="graph">
          <strong class="bar_<%= color(ratio(usage, limit)) %>" style="width: <%= ratio(usage, limit) %>%;"><%= ratio(usage, limit) %>%</strong>
        </div>
      </td>
      <% else %>
      <td> - </td>
      <td> - </td>
      <td> - </td>
      <td> - </td>
      <% end %>
    </tr>
    <% end %>
  </table>
<% end %>
<br>