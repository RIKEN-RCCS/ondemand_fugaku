<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
  # spack versions phase0 -s
  versions        = [["3D", "3D", "data-hide-twod-version: true, data-hide-twod-exec: true"], ["2D", "2D", "data-hide-threed-version: true, data-hide-threed-exec: true"]]
  threed_versions = [["2023.01", "lhct42t"]]
  twod_versions   = [["2023.01", "jnmmtmd"]]
  threed_execs    = ["phase.3d"]
  twod_execs      = ["phase", "ekcal"]
-%>
---
title: PHASE/0
form:
<%= form_queue("fugaku_small") %>
<%= form_select("version", "Version", versions) %>
<%= form_select("threed_version", "3D version", threed_versions) %>
<%= form_select("twod_version",   "2D version", twod_versions) %>
<%= form_select("threed_exec", "3D Executable file", threed_execs) %>
<%= form_select("twod_exec",   "2D Executable file", twod_execs) %>
<%= form_working_dir() %>
<%= form_options("e.g. ne=8 nk=4") %>
<%= form_email(false) %>
attributes:
<%= form_attr() %>
