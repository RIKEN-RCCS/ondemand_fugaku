<%-
  require '/var/www/ood/apps/sys/ondemand_apps/misc/info.rb'
  dirs = get_favorites_dirs()
-%>
---
title: Paraview
form:
  - cluster
  - queue
  - prepost1_hours
  - prepost2_hours
  - gpu1_cores
  - gpu2_cores
  - mem1_cores
  - mem2_cores
  - gpu1_memory
  - gpu2_memory
  - mem1_memory
  - mem2_memory
  - gpus_per_node
  - filename
  - email
  - bc_vnc_resolution
  - desktop
attributes:
  cluster:
    widget: hidden_field
    value: prepost
  queue:
    label: Queue
    widget: select
    options:
      - [ "prepost-gpu1", "gpu1",
          data-hide-prepost2-hours: true,
          data-hide-gpu2-cores: true,
          data-hide-mem1-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true ]
      - [ "prepost-gpu2", "gpu2",
          data-hide-prepost1-hours: true,
          data-hide-gpu1-cores: true,
          data-hide-mem1-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu1-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true ]
      - [ "prepost-mem1", "mem1",
          data-hide-prepost2-hours: true,
          data-hide-gpus-per-node: true,
          data-hide-gpu1-cores: true,
          data-hide-gpu2-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu1-memory: true,
          data-hide-gpu2-memory: true,
          data-hide-mem2-memory: true ]
      - [ "prepost-mem2", "mem2",
          data-hide-prepost1-hours: true,
          data-hide-gpus-per-node: true,
          data-hide-gpu1-cores: true,
          data-hide-gpu2-cores: true,
          data-hide-mem1-cores: true,
          data-hide-gpu1-memory: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true ]
  prepost1_hours:
    widget: number_field
    label: Elapsed Time (1 - 3 hours)
    value: 1
    min: 1
    max: 3
    step: 1
  prepost2_hours:
    widget: number_field
    label: Elapsed Time (1 - 24 hours)
    value: 1
    min: 1
    max: 24
    step: 1
  gpu1_cores:
    widget: number_field
    label: Number of CPU cores (1 - 72)
    value: 1
    min: 1
    max: 72
    step: 1
  gpu2_cores:
    widget: number_field
    label: Number of CPU cores (1 - 36)
    value: 1
    min: 1
    max: 36
    step: 1
  mem1_cores:
    widget: number_field
    label: Number of CPU cores (1 - 224)
    value: 1
    min: 1
    max: 224
    step: 1
  mem2_cores:
    widget: number_field
    label: Number of CPU cores (1 - 56)
    value: 1
    min: 1
    max: 56
    step: 1
  gpu1_memory:
    widget: number_field
    label: Required memory (5 - 186 GB)
    value: 5
    min: 5
    max: 186
    step: 1
  gpu2_memory:
    widget: number_field
    label: Required memory (5 - 93 GB)
    value: 5
    min: 5
    max: 93
    step: 1
  mem1_memory:
    widget: number_field
    label: Required memory (5 - 5020 GB)
    value: 5
    min: 5
    max: 5020
    step: 1
  mem2_memory:
    widget: number_field
    label: Required memory (5 - 1500 GB)
    value: 5
    min: 5
    max: 1500
    step: 1
  gpus_per_node:
    widget: number_field
    label: Number of GPUs (0 - 2)
    value: 0
    min: 0
    max: 2
    step: 1
  filename:
    label: 'Input File'
    data-filepicker: true
    data-target-file-type: files  # Valid values are: files, dirs, or both
    # Optionally set a default directory
    data-default-directory: <%= ENV['HOME'] %>
    # Optionally only allow editing through the file picker; defaults to false
    data-file_picker_favorites: <%= dirs %>
    #data-file_picker_favorites: '[{"title": "Home Directory", "href": "<%= ENV['HOME'] %>"}]'
  email:
    widget: email_field
    label: Email (You will receive an email when it starts)
  bc_vnc_resolution:
    required: true
  desktop:
    widget: hidden_field
    value: xfce
