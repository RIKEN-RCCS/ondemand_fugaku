<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
-%>
---
script:
  job_name: ood_openfoam_<%= version %>
  queue_name: <%= queue %>
  <%= submit_email(email, false) %>
  <%= submit_native_fugaku(queue, fugaku_small_hours, fugaku_small_free_hours, fugaku_small_nodes, fugaku_small_procs,
  fugaku_large_hours, fugaku_large_free_hours, fugaku_large_nodes, fugaku_large_procs, fugaku_group, fugaku_mode,
  fugaku_statistical_info, working_dir) %>
batch_connect:
  template: "basic"
  script_wrapper: |
    #!/usr/bin/env bash
    set -e
    . /vol0004/apps/oss/spack/share/spack/setup-env.sh
    if [ "<%= version %>" = "foundation" ]; then
      spack load openfoam-org@<%= foundation_version %>
    else
      spack load openfoam@<%= opencfd_version %>
    fi
    <%= submit_fugaku_llio(queue, fugaku_llio, working_dir) %>
    
    cd "<%= working_dir %>"
    <% commands.split("\r\n").each do |c| %>
    <%= c.strip -%>
    <% end %>
