<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/form.rb'

  versions            = [["Foundation", "foundation", "data-hide-opencfd-version: true"], ["OpenCFD", "opencfd", "data-hide-foundation-version: true"]]
  foundation_versions = ["10", "9", "8"]
  opencfd_versions    = ["2212", "2206", "2112", "2106", "2012"]
-%>
---
title: OpenFOAM
form:
  <%= form_cluster("fugaku") %>
  <%= form_queue("fugaku_small_and_large") %>
  <%= form_volume() %>
  <%= form_group() %>
  <%= form_fugaku_small_hours() %>
  <%= form_fugaku_small_free_hours() %>
  <%= form_fugaku_small_nodes() %>
  <%= form_fugaku_small_procs() %>
  <%= form_fugaku_large_hours() %>
  <%= form_fugaku_large_free_hours() %>
  <%= form_fugaku_large_nodes() %>
  <%= form_fugaku_large_procs() %>
  <%= form_mode() %>
  <%= form_working_dir() %>
  <%= form_select("version", "Version", versions) %>
  <%= form_select("foundation_version", "Foundation version", foundation_versions) %>
  <%= form_select("opencfd_version",    "OpenCFD version",    opencfd_versions) %>
  <%= form_commands("e.g. mpiexec interFoam -parallel") %>
  <%= form_llio("working_dir", "If you transfer the executable file, for example, please add 'lilo_transfer $(which interFoam)' in commands area.") %>
  <%= form_email(false) %>
attributes:
<%= form_attr() %>
