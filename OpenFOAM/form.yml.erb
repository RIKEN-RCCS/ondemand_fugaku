<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'

  versions            = [["Foundation", "foundation", "data-hide-opencfd-version: true"], ["OpenCFD", "opencfd", "data-hide-foundation-version: true"]]
  foundation_versions = ["11", "10", "9"]
  opencfd_versions    = ["2312", "2306", "2212"]
-%>
---
title: OpenFOAM
form:
<%= form_queue("fugaku_small_and_large", false) %>
<%= form_working_dir() %>
<%= form_select("version", "Version", versions) %>
<%= form_select("foundation_version", "Foundation version", foundation_versions) %>
<%= form_select("opencfd_version",    "OpenCFD version",    opencfd_versions) %>
<%= form_commands("e.g. mpiexec interFoam -parallel") %>
<%= form_fugaku_llio("working_dir", "If you transfer the executable file, for example, please add 'lilo_transfer $(which interFoam)' in commands area.") %>
<%= form_email(false) %>
attributes:
<%= form_attr() %>
