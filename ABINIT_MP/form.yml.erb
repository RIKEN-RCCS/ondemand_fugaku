<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
  
  # spack versions abinitmp -s
  versions = ["2-4", "1-22"]
  # spack find --paths abinitmp@2-4
  ab = []
  ab.push(form_load_cache("ab2-4"))
  ab.push(form_load_cache("ab1-22"))
-%>
---
title: ABINIT-MP
form:
  <%= form_cluster("fugaku") %>
  <%= form_queue("fugaku_small_and_large") %>
  <%= form_fugaku_group() %>
  <%= form_hours("fugaku_small") %>
  <%= form_hours("fugaku_small_free") %>
  <%= form_nodes("fugaku_small") %>
  <%= form_procs("fugaku_small") %>
  <%= form_hours("fugaku_large") %>
  <%= form_hours("fugaku_large_free") %>
  <%= form_nodes("fugaku_large") %>
  <%= form_procs("fugaku_large") %>
  <%= form_fugaku_threads() %>
  <%= form_fugaku_mode() %>
  <%= form_version(versions) %>
  <%= form_exec(versions[0], ab[0], "abinitmp") %>
  <%= form_exec(versions[1], ab[1], "abinitmp") %>
  <%= form_working_dir(false) %>
  <%= form_input_file(true, "mpiexec [executable] < [input]") %>
  <%= form_fugaku_llio("input_file") %>
  <%= form_email(false) %>
attributes:
<%= form_attr() %>
