<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
-%>
---
script:
  job_name: ood_hphi
  queue_name: <%= queue %>
  <%= submit_email(email, false) %>
  <%= submit_native_fugaku(queue, fugaku_small_hours, fugaku_small_free_hours, fugaku_small_nodes, fugaku_small_procs, fugaku_large_hours, fugaku_large_free_hours, fugaku_large_nodes, fugaku_large_procs, group, volume, mode) %>
batch_connect:
  template: "basic"
  script_wrapper: |
    <%= submit_env(fugaku_threads, "hphi", version) %>
    <%= submit_llio_exec_file(queue, fugaku_large_nodes, fugaku_large_procs, "HPhi") %>
    <%= submit_llio(queue, fugaku_llio, input_file) %>
    <%= submit_working_dir(working_dir) %>
    mpiexec HPhi <%= se_mode %> "<%= input_file %>"
