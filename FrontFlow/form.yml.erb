<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'

  apps = [["FrontFlow/blue", "blue", "data-hide-x-version: true"], ["FrontFlowX", "x", "data-hide-b-version: true"]]
  # spack versions ffb -s
  b_versions = ["9.0"]
  # spack versions ffx -s
  x_versions = ["59.01"]
-%>
---
title: FrontFlow
form:
<%= form_queue("fugaku_small") %>
<%= form_select("app",       "Application"             , apps) %>
<%= form_select("b_version", "Version (FrontFlow/blue)", b_versions) %>
<%= form_select("x_version", "Version (FrontFlowX)",     x_versions) %>
<%= form_working_dir() %>
<%= form_email(false) %>
attributes:
<%= form_attr() %>
