<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
  # spack versions modylas-new -s
  versions = ["1.1.0b"]
  # spack find --paths modylas-new@1.1.0b
  modylas110b = form_load_cache("modylas110b")  
-%>
---
title: MODYLAS
form:
  <%= form_cluster("fugaku") %>
  <%= form_queue("fugaku_small_and_large") %>
  <%= form_group() %>
  <%= form_fugaku_small_hours() %>
  <%= form_fugaku_small_free_hours() %>
  <%= form_fugaku_small_nodes() %>
  <%= form_fugaku_small_procs() %>
  <%= form_fugaku_large_hours() %>
  <%= form_fugaku_large_free_hours() %>
  <%= form_fugaku_large_nodes() %>
  <%= form_fugaku_large_procs() %>
  <%= form_fugaku_threads() %>
  <%= form_mode() %>
  <%= form_working_dir() %>
  <%= form_version(versions) %>
  <%= form_exec(versions[0], modylas110b, "modylas") %>
  <%= form_session_name() %>
  <%= form_llio("working_dir") %>
  <%= form_email(false) %>
attributes:
<%= form_attr() %>
