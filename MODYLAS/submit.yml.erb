<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/submit.rb'
-%>
---
script:
  job_name: ood_modylas
  queue_name: <%= queue %>
  <%= submit_email(email, false) %>
  <%= submit_native_fugaku(fugaku_hours, fugaku_nodes, fugaku_procs, group, volume, mode) %>
batch_connect:
  template: "basic"
  script_wrapper: |
    <%= submit_env(fugaku_threads, "modylas-new", version) %>
    
    cd <%= working_dir %>
    mpiexec <%= binary_110b %> <%= session_name %>
