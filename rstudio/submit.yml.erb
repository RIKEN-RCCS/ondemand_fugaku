script:
  job_name: ood_rstudio
  <%- if cluster == "prepost" then -%>
  queue_name: <%= queue %>
  <%- if queue == "gpu1" or queue == "gpu2" then -%>
  gpus_per_node: <%= gpus_per_node %>
  <%- end -%>
  <%- end -%>
  <%- if email.present? -%>
  email: <%= email %>
  email_on_started: true
  <%- end -%>
  native:
  <%- if cluster == "fugaku" -%>
    - "-L elapse=<%= fugaku_num_hours %>:00:00,node=1,jobenv=singularity --mpi proc=48 --no-check-directory -g <%= group %>"
    <%- if volume == "/vol0004" -%>
    - "-x PJM_LLIO_GFSCACHE=/vol0004"
    <%- else -%>
    - "-x PJM_LLIO_GFSCACHE=/vol0004:<%= volume %>"
    <%- end -%>
    <%- if boost_mode == "1" and eco_mode == "1" -%>
    - "-L freq=2200,eco_state=2"
    <%- elsif boost_mode == "1" -%>
    - "-L freq=2200"
    <%- elsif eco_mode == "1" -%>
    - "-L eco_state=2"
    <%- end -%>
  <%- elsif cluster == "prepost" then -%>
    <%- if queue == "gpu1" -%>
      - "-t"
      - "<%= prepost1_num_hours %>:00:00"
      - "-n"
      - <%= gpu1_num_cores.to_i %>
      - "--mem"
      - "<%= gpu1_required_memory %>G"
    <%- elsif queue == "gpu2" then -%>
      - "-t"
      - "<%= prepost2_num_hours %>:00:00"
      - "-n"
      - <%= gpu2_num_cores.to_i %>
      - "--mem"
      - "<%= gpu2_required_memory %>G"
    <%- elsif queue == "mem1" then -%>
      - "-t"
      - "<%= prepost1_num_hours %>:00:00"
      - "-n"
      - <%= mem1_num_cores.to_i %>
      - "--mem"
      - "<%= mem1_required_memory %>G"
    <%- elsif queue == "mem2" then -%>
      - "-t"
      - "<%= prepost2_num_hours %>:00:00"
      - "-n"
      - <%= mem2_num_cores.to_i %>
      - "--mem"
      - "<%= mem2_required_memory %>G"
    <%- elsif queue == "small-dormant-lingering-jobs-only" then -%>
      - "-t"
      - "<%= prepost_wheel_num_hours %>:00:00"
      - "-n"
      - <%= gpu1_num_cores.to_i %>
      - "--mem"
      - "<%= gpu1_required_memory %>G"
    <%- end -%>
  <%- end -%>
batch_connect:
  template: "basic"
  conn_params:
    - csrf_token
