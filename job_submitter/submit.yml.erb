<%-
  require '/var/www/ood/apps/sys/ondemand_apps/misc/submit.rb'
-%>
---
script:
  job_name: ood_job_submitter
  queue_name: <%= queue %>
  <%= submit_gpus_per_node(queue, gpus_per_node) %>
  <%= submit_email(email, false) %>
  <%= submit_native(cluster, fugaku_hours, fugaku_nodes, fugaku_procs,
  group, volume, mode, queue, prepost1_hours, gpu1_cores, gpu1_memory,
  prepost2_hours, gpu2_cores, gpu2_memory, mem1_cores, mem1_memory,
  mem2_cores, mem2_memory, reserved_hours, reserved_cores, reserved_memory) %>
batch_connect:
  template: "basic"
