<%-
  require '/var/www/ood/apps/sys/ondemand_apps/misc/cache.rb'
  fdirs = get_groups_fdirs()
-%>
---
title: VESTA
form:
  - cluster
  - queue
  - prepost1_hours
  - prepost2_hours
  - prepost_reserved_hours
  - gpu1_memory
  - gpu2_memory
  - mem1_memory
  - mem2_memory
  - reserved_memory
  - email
  - bc_vnc_resolution
  - desktop
attributes:
  cluster:
    widget: hidden_field
    value: prepost
  queue:
    label: Queue
    widget: select
    options:
      - [ "prepost-gpu1", "gpu1",
          data-hide-prepost2-hours: true,
	  data-hide-prepost-reserved-hours: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true,
	  data-hide-reserved-memory: true ]
      - [ "prepost-gpu2", "gpu2",
          data-hide-prepost1-hours: true,
	  data-hide-prepost-reserved-hours: true,
          data-hide-gpu1-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true,
	  data-hide-reserved-memory: true ]
      - [ "prepost-mem1", "mem1",
          data-hide-prepost2-hours: true,
	  data-hide-prepost-reserved-hours: true,
          data-hide-gpu1-memory: true,
          data-hide-gpu2-memory: true,
          data-hide-mem2-memory: true,
	  data-hide-reserved-memory: true ]
      - [ "prepost-mem2", "mem2",
          data-hide-prepost1-hours: true,
	  data-hide-prepost-reserved-hours: true,
          data-hide-gpu1-memory: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true,
	  data-hide-reserved-memory: true ]
      - [ "prepost-ondemand-reserved", "ondemand-reserved",
          data-hide-prepost1-hours: true,
          data-hide-prepost2-hours: true,
          data-hide-gpu1-memory: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true ]
  prepost1_hours:
    widget: number_field
    label: Elapsed time (1 - 3 hours)
    value: 1
    min: 1
    max: 3
    step: 1
    required: true
  prepost2_hours:
    widget: number_field
    label: Elapsed time (1 - 24 hours)
    value: 1
    min: 1
    max: 24
    step: 1
    required: true
  prepost_reserved_hours:
    widget: number_field
    label: Elapsed time (1 - 720 hours)
    value: 1
    min: 1
    max: 720
    step: 1
    required: true
  gpu1_memory:
    widget: number_field
    label: Required memory (5 - 186 GB)
    value: 5
    min: 5
    max: 186
    step: 1
    required: true
  gpu2_memory:
    widget: number_field
    label: Required memory (5 - 93 GB)
    value: 5
    min: 5
    max: 93
    step: 1
    required: true
  mem1_memory:
    widget: number_field
    label: Required memory (5 - 5020 GB)
    value: 5
    min: 5
    max: 5020
    step: 1
    required: true
  mem2_memory:
    widget: number_field
    label: Required memory (5 - 1500 GB)
    value: 5
    min: 5
    max: 1500
    step: 1
    required: true
  reserved_memory:
    widget: number_field
    label: Required memory (5 - 32 GB)
    value: 5
    min: 5
    max: 32
    step: 1
    required: true
  email:
    widget: email_field
    label: Email (You will receive an email when it starts)
  bc_vnc_resolution:
    required: true
  desktop:
    widget: hidden_field
    value: xfce
