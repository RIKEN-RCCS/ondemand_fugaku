#!/usr/bin/env bash

export XDG_DATA_HOME=${HOME}/ondemand/vscode/`arch`
export XDG_RUNTIME_DIR=${XDG_DATA_HOME}/tmp
EXTENSIONS=${XDG_DATA_HOME}/extensions

# Expose the password to the server.
export PASSWORD="$password"

# Print compute node.
echo "$(date): Running on compute node ${compute_node}:$port"

WORKING_DIR="<%= context.global_working_dir %>"
mkdir -p ${WORKING_DIR} ${EXTENSIONS}

/home/apps/oss/vscode/`arch`/bin/code-server \
  --auth="password" \
  --bind-addr="0.0.0.0:${port}" \
  --disable-telemetry \
  --extensions-dir="${EXTENSIONS}" \
  --user-data-dir="${XDG_DATA_HOME}" \
  --log debug --disable-update-check --ignore-last-opened \
  "${WORKING_DIR}"
