<%-
  require '/var/www/ood/apps/sys/ondemand_apps/misc/info.rb'
  groups = get_groups()
-%>
---
title: Remote Desktop
form:
  - cluster
  - queue
  - volume
  - group
  - fugaku_hours
  - fugaku_nodes
  - fugaku_procs
  - prepost1_hours
  - prepost2_hours
  - gpu1_cores
  - gpu2_cores
  - mem1_cores
  - mem2_cores
  - gpu1_memory
  - gpu2_memory
  - mem1_memory
  - mem2_memory
  - gpus_per_node
  - mode
  - email
  - desktop
attributes:
  queue:
    label: Queue
    widget: select
    options:
      - [ "fugaku-small", "fugaku", data-set-cluster: "fugaku",
          data-hide-cluster: true,
          data-hide-prepost1-hours: true,
          data-hide-prepost2-hours: true,
          data-hide-gpus-per-node: true,
          data-hide-gpu1-cores: true,
          data-hide-gpu2-cores: true,
          data-hide-mem1-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu1-memory: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true ]
      - [ "prepost-gpu1", "gpu1", data-set-cluster: "prepost",
          data-hide-cluster: true,
          data-hide-group: true,
	  data-hide-fugaku-hours: true,
	  data-hide-fugaku-nodes: true,
	  data-hide-fugaku-procs: true,
          data-hide-prepost2-hours: true,
          data-hide-gpu2-cores: true,
          data-hide-mem1-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true,
	  data-hide-mode: true ]
      - [ "prepost-gpu2", "gpu2", data-set-cluster: "prepost",
          data-hide-cluster: true,
          data-hide-group: true,
          data-hide-fugaku-hours: true,
	  data-hide-fugaku-nodes: true,
	  data-hide-fugaku-procs: true,
          data-hide-prepost1-hours: true,
          data-hide-gpu1-cores: true,
          data-hide-mem1-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu1-memory: true,
          data-hide-mem1-memory: true,
          data-hide-mem2-memory: true,
	  data-hide-mode: true ]
      - [ "prepost-mem1", "mem1", data-set-cluster: "prepost",
          data-hide-cluster: true,
          data-hide-group: true,
          data-hide-fugaku-hours: true,
	  data-hide-fugaku-nodes: true,
	  data-hide-fugaku-procs: true,
          data-hide-prepost2-hours: true,
          data-hide-gpus-per-node: true,
          data-hide-gpu1-cores: true,
          data-hide-gpu2-cores: true,
          data-hide-mem2-cores: true,
          data-hide-gpu1-memory: true,
          data-hide-gpu2-memory: true,
          data-hide-mem2-memory: true,
	  data-hide-mode: true ]
      - [ "prepost-mem2", "mem2", data-set-cluster: "prepost",
          data-hide-cluster: true,
          data-hide-group: true,
          data-hide-fugaku-hours: true,
	  data-hide-fugaku-nodes: true,
	  data-hide-fugaku-procs: true,
          data-hide-prepost1-hours: true,
          data-hide-gpus-per-node: true,
          data-hide-gpu1-cores: true,
          data-hide-gpu2-cores: true,
          data-hide-mem1-cores: true,
          data-hide-gpu1-memory: true,
          data-hide-gpu2-memory: true,
          data-hide-mem1-memory: true,
	  data-hide-mode: true ]
  volume:
    widget: hidden_field
  group:
    label: Group
    widget: select
    options:
    <%- groups.each do |group| -%>
      - <%= group %>
    <%- end -%>
  fugaku_hours:
    widget: number_field
    label: Elapsed Time (1 - 72 hours)
    value: 1
    min: 1
    max: 72
    step: 1
  fugaku_nodes:
    widget: number_field
    label: Number of nodes (1 - 384 nodes)
    value: 1
    min: 1
    max: 384
    step: 1
  fugaku_procs:
    widget: number_field
    label: Total number of processes (1 - 18,432)
    value: 48
    min: 1
    max: 18432
    step: 1
    help: |
      The maximum value is the number of nodes x 48.
  prepost1_hours:
    widget: number_field
    label: Elapsed Time (1 - 3 hours)
    value: 1
    min: 1
    max: 3
    step: 1
  prepost2_hours:
    widget: number_field
    label: Elapsed Time (1 - 24 hours)
    value: 1
    min: 1
    max: 24
    step: 1
  gpu1_cores:
    widget: number_field
    label: Number of CPU cores (1 - 72)
    value: 1
    min: 1
    max: 72
    step: 1
  gpu2_cores:
    widget: number_field
    label: Number of CPU cores (1 - 36)
    value: 1
    min: 1
    max: 36
    step: 1
  mem1_cores:
    widget: number_field
    label: Number of CPU cores (1 - 224)
    value: 1
    min: 1
    max: 224
    step: 1
  mem2_cores:
    widget: number_field
    label: Number of CPU cores (1 - 56)
    value: 1
    min: 1
    max: 56
    step: 1
  gpu1_memory:
    widget: number_field
    label: Required memory (10 - 186 GB)
    value: 10
    min: 10
    max: 186
    step: 1
  gpu2_memory:
    widget: number_field
    label: Required memory (10 - 93 GB)
    value: 10
    min: 10
    max: 93
    step: 1
  mem1_memory:
    widget: number_field
    label: Required memory (10 - 5020 GB)
    value: 10
    min: 10
    max: 5020
    step: 1
  mem2_memory:
    widget: number_field
    label: Required memory (10 - 1500 GB)
    value: 10
    min: 10
    max: 1500
    step: 1
  gpus_per_node:
    widget: number_field
    label: Number of GPUs (0 - 2)
    value: 0
    min: 0
    max: 2
    step: 1
  mode:
    widget: select
    label: Mode
    options:
    - Normal
    - Boost
    - Eco
    - Boost + Eco
  email:
    widget: email_field
    label: Email (You will receive an email when it starts)
  desktop:
    widget: hidden_field
    value: xfce
