<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
-%>
---
script:
  job_name: ood_gromacs
  queue_name: <%= queue %>
  <%= submit_email(email, false) %>
  <%= submit_native_fugaku_small(queue, fugaku_small_hours, fugaku_small_free_hours, fugaku_small_nodes, fugaku_small_procs, fugaku_group, fugaku_mode) %>
batch_connect:
  template: "basic"
  script_wrapper: |
    <%= submit_env(fugaku_threads, "gromacs", version) %>
    
    cd "<%= working_dir %>"
    mpiexec gmx_mpi <%= options %>
