<%-
  require '/var/www/ood/apps/sys/ondemand_apps/misc/submit.rb'
-%>
---
script:
  job_name: ood_gromacs
  queue_name: <%= queue %>
  <%= submit_email(email, false) %>
  <%= submit_native_fugaku(fugaku_hours, fugaku_nodes, fugaku_procs, group, volume, mode) %>
batch_connect:
  template: "basic"
  script_wrapper: |
    #!/bin/bash
    export OMP_NUM_THREADS=<%= fugaku_threads %>
    . /vol0004/apps/oss/spack/share/spack/setup-env.sh
    spack load gromacs@<%= version %>
    
    cd <%= working_dir %>
    mpiexec gmx_mpi <%= options %>
