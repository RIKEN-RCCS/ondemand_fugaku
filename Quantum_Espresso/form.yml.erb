---
form:
  - cluster
  - queue
  - volume
  - group
  - fugaku_hours
  - fugaku_nodes
  - fugaku_procs
  - fugaku_threads
  - mode
  - version
  - binary_71
  - binary_68
  - binary_67
  - binary_66
  - binary_65
  - filename
  - options
  - email
attributes:
  <%= get_cluster("fugaku") %>
  <%= get_queue("fugaku_small") %>
  <%= get_volume() %>
  <%= get_group() %>
  <%= get_fugaku_hours() %>
  <%= get_fugaku_nodes() %>
  <%= get_fugaku_procs() %>
  <%= get_fugaku_threads() %>
  <%= get_mode() %>
  <%= get_version(versions) %>
  <%= get_binary(versions[0], qe[0], "pw.x") %>
  <%= get_binary(versions[1], qe[1], "pw.x") %>
  <%= get_binary(versions[2], qe[2], "pw.x") %>
  <%= get_binary(versions[3], qe[3], "pw.x") %>
  <%= get_binary(versions[4], qe[4], "pw.x") %>
  <%= get_filename("-in <input>") %>
  <%= get_options("e.g. -nk 2") %>
  <%= get_email(1) %>
