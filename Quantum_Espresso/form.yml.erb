---
title: Quantum Espresso
form:
  <%= form_cluster("fugaku") %>
  <%= form_queue("fugaku_small") %>
  <%= form_volume() %>
  <%= form_group() %>
  <%= form_fugaku_small_hours() %>
  <%= form_fugaku_small_free_hours() %>
  <%= form_fugaku_small_nodes() %>
  <%= form_fugaku_small_procs() %>
  <%= form_fugaku_threads() %>
  <%= form_mode() %>
  <%= form_version(versions) %>
  <%= form_exec(versions[0], qe[0], "pw.x") %>
  <%= form_exec(versions[1], qe[1], "pw.x") %>
  <%= form_exec(versions[2], qe[2], "pw.x") %>
  <%= form_exec(versions[3], qe[3], "pw.x") %>
  <%= form_exec(versions[4], qe[4], "pw.x") %>
  <%= form_working_dir(false) %>
  <%= form_input_file(true, "-in [input]") %>
  <%= form_options("e.g. -nk 2") %>
  <%= form_email(false) %>
attributes:
<%= form_attr() %>
