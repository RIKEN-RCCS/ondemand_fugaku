<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
  
  # spack versions quantum-espresso -s
  versions = ["7.2", "7.1", "6.8", "6.7"]
  # spack find --paths quantum-espresso@7.2
  qe = []
  qe.push(form_load_cache("quantum_espresso72"))
  qe.push(form_load_cache("quantum_espresso71"))
  qe.push(form_load_cache("quantum_espresso68"))
  qe.push(form_load_cache("quantum_espresso67"))
-%>
---
title: Quantum Espresso
form:
<%= form_queue("fugaku_small") %>
<%= form_version(versions) %>
<%= form_exec(versions[0], qe[0], "pw.x") %>
<%= form_exec(versions[1], qe[1], "pw.x") %>
<%= form_exec(versions[2], qe[2], "pw.x") %>
<%= form_exec(versions[3], qe[3], "pw.x") %>
<%= form_working_dir2(false) %>
<%= form_input_file2(true, "-in [input]") %>
<%= form_options("e.g. -nk 2") %>
<%= form_email(false) %>
attributes:
<%= form_attr() %>
