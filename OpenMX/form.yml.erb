<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
  # spack versions openmx -s
  versions = ["3.9"]
  # spack find --paths openmx@3.9
  openmx39 = form_load_cache("openmx39")
-%>
---
title: OpenMX
form:
  <%= form_cluster("fugaku") %>
  <%= form_queue("fugaku_small") %>
  <%= form_fugaku_group() %>
  <%= form_hours("fugaku_small") %>
  <%= form_hours("fugaku_small_free") %>
  <%= form_nodes("fugaku_small") %>
  <%= form_procs("fugaku_small") %>
  <%= form_fugaku_threads() %>
  <%= form_fugaku_mode() %>
  <%= form_fugaku_statistical_info() %>
  <%= form_version(versions) %>
  <%= form_exec(versions[0], openmx39, "openmx") %>
  <%= form_working_dir(false) %>
  <%= form_input_file() %>
  <%= form_options("e.g. –nt 2") %>
  <%= form_email(false) %>
attributes:
<%= form_attr() %>
