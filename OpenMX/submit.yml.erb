<%-
  require '/var/www/ood/apps/sys/ondemand_fugaku/misc/utils.rb'
-%>
---
script:
  job_name: ood_openmx
  queue_name: <%= queue %>
  <%= submit_email(email, false) %>
  <%= submit_native_fugaku_small(queue, fugaku_small_hours, fugaku_small_free_hours, fugaku_small_nodes, fugaku_small_procs, group, mode) %>
batch_connect:
  template: "basic"
  script_wrapper: |
    <%= submit_env(fugaku_threads, "openmx", version) %>
    <%= submit_working_dir(working_dir) %>
    FILE="$(basename "<%= input_file %>")"  # Full path doesn't work.
    mpiexec <%= eval("exec_#{version.delete(".")}") %> "${FILE}" <%= options %>
