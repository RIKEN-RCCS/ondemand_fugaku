<%-
  require '/var/www/ood/apps/sys/ondemand_apps/misc/cache.rb'
  # spack versions openmx -s
  versions=["3.9"]
  # spack find --paths openmx@3.9
  openmx39 = get_bins("openmx39", "/vol0004/apps/oss/spack-v0.19/opt/spack/linux-rhel8-a64fx/fj-4.8.1/openmx-3.9-j52bvdtvorjy2stvpf7ve2ygxogwjw4n/bin/")

  groups = get_groups()
  fdirs  = get_groups_fdirs()
-%>
---
form:
  - cluster
  - queue
  - volume
  - group
  - hours_in_three_days
  - hours_in_one_day
  - small_nodes
  - large_nodes
  - middle_nodes
  - small_procs
  - large_procs
  - middle_procs
  - threads
  - mode
  - version
  - binary39
  - filename
  - options
  - email
attributes:
  cluster:
    widget: hidden_field
    value: fugaku
  queue:
    label: Queue
    widget: select
    options:
      - [ "fugaku-small", "small", 
	  data-hide-hours-in-one-day: true,
	  data-hide-large-nodes: true, data-hide-middle-nodes: true,
	  data-hide-large-procs: true, data-hide-middle-procs: true ]
#      - [ "fugaku-large",  "large" , 
#	  data-hide-hours-in-three-days: true,
#	  data-hide-small-nodes: true, data-hide-middle-nodes: true,
#	  data-hide-small-procs: true, data-hide-middle-procs: true ]
#      - [ "fugaku-middle", "middle", 
#	  data-hide-hours-in-three-days: true,
#	  data-hide-small-nodes: true, data-hide-large-nodes: true,
#	  data-hide-small-procs: true, data-hide-large-procs: true ]
  volume:
    widget: hidden_field
  group:
    label: Group
    widget: select
    options:
    <%- groups.each do |group| -%>
      - <%= group %>
    <%- end -%>
  hours_in_three_days:
    widget: number_field
    label: Elapsed Time (1 - 72 hours)
    value: 1
    min: 1
    max: 72
    step: 1
    required: true
  hours_in_one_day:
    widget: number_field
    label: Elapsed Time (1 - 24 hours)
    value: 1
    min: 1
    max: 24
    step: 1
    required: true
  small_nodes:
    widget: number_field
    label: Number of nodes (1 - 384)
    value: 1
    min: 1
    max: 384
    step: 1
    required: true
  large_nodes:
    widget: number_field
    label: Number of nodes (385 - 12,288)
    value: 385
    min: 385
    max: 12288
    step: 1
    required: true
  middle_nodes:
    widget: number_field
    label: Number of nodes (12,289 - 55,296)
    value: 12289
    min: 12289
    max: 55296
    step: 1
    required: true
  small_procs:
    widget: number_field
    label: Total number of processes (1 - 18,432)
    value: 1
    min: 1
    max: 18432
    step: 1
    required: true
    help: |
      Total number of processes <= Number of nodes x 48.
  large_procs:
    widget: number_field
    label: Total number of processes (1 - 589,824)
    value: 385
    min: 1
    max: 18432
    step: 1
    required: true
    help: |
      Total number of processes <= Number of nodes x 48.
  middle_procs:
    widget: number_field
    label: Total number of processes (1 - 2,654,208)
    value: 12289
    min: 1
    max: 2654208
    step: 1
    required: true
    help: |
      Total number of processes <= Number of nodes x 48.
  threads:
    widget: number_field
    label: Number of threads (1 - 48)
    value: 1
    min: 1
    max: 48
    step: 1
    required: true
    help: |
      Number of threads x Total number of processes <= Number of nodes x 48.
  mode:
    widget: select
    label: Mode
    options:
    - Normal
    - Boost
    - Eco
    - Boost + Eco
  version:
    widget: select
    label: Version
    options:
    <%- str="" -%>
    <%- versions.each do |v| -%>
    <%- str = "[" + v + ", " + v -%>
    <%- versions.each do |i| -%>
      <%- str += ", data-hide-binary" + i.delete(".") + ": true" unless i == v -%>
    <%- end -%>
    - <%= str + "]" %>
    <%- end -%>
  binary39:
    widget: select
    label: Binary file version 3.9
    value: openmx
    options:
    <%- openmx39.each do |b| -%>
      - <%= b %>
    <%- end -%>
  filename:
    label: 'Input File (mpiexec openmx <input>)'
    data-filepicker: true
    data-target-file-type: files  # Valid values are: files, dirs, or both
    # Optionally set a default directory
    data-default-directory: <%= ENV['HOME'] %>
    # Optionally only allow editing through the file picker; defaults to false
    data-file_picker_favorites: <%= fdirs %>
  options:
    label: Options (e.g. –nt 2)
    widget: text_field
  email:
    label: Email (You will receive an email when it starts and ends)
    widget: email_field
